# Application
APP_NAME="BAC Scanner"
DEBUG=true
SECRET_KEY="my-super-secret-key-for-testing"

# Database (Switched to SQLite for local testing! 🔥)
DATABASE_URL="sqlite+aiosqlite:///./demo.db"

# Redis (for Celery - won't crash the app if you aren't actively calling it yet)
REDIS_URL="redis://localhost:6379/0"

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Demo Target
DEMO_TARGET_URL="http://localhost:8001"